<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>OUT_RayMicro</AssemblyName>
    <RootNamespace>OUT_RayMicro</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <Reference Include="Raylib-cs" HintPath="tools\Raylib-cs.dll" Private="true" />
    <None Include="tools\**\*.*" CopyToOutputDirectory="PreserveNewest" CopyToPublishDirectory="PreserveNewest" />
  </ItemGroup>
</Project>
